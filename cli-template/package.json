{
  "name": "project.name",
  "productName": "{{project.productName}}",
  "version": "0.1.0",
  "description": "{{project.description}}",
  "type": "module",
  "main": "dist/src/start.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node dist/src/start.js",
    "build": "tsc",
    "clean": "rimraf dist",
    "cb": "npm run clean && npm run build",
    "ci": "node --no-deprecation ./scripts/npm/run.js",
    "reinstall": "node --no-deprecation ./scripts/npm/run.js reinstall",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "quality": "npm run lint && npm run format",
    "quality:fix": "npm run lint:fix && npm run format:fix",
    "lint-fix-build": "oxlint --fix . && oxfmt . && rimraf dist && tsc",
    "generate-token": "node node_modules/fa-mcp-sdk/dist/core/auth/token-generator/server.js",
    "dead:exports": "ts-prune",
    "dead:files": "knip",
    "update-sdk-docs": "node ../scripts/update-sdk.js",
    "postinstall": "node ../scripts/npm/patch_node_modules.js",
    "check-llm": "node node_modules/fa-mcp-sdk/dist/core/agent-tester/check-llm.js",
    "consul:unreg": "node node_modules/fa-mcp-sdk/dist/core/consul/deregister.js",
    "test": "jest",
    "test:mcp": "node tests/mcp/test-stdio.js",
    "test:mcp-http": "node tests/mcp/test-http.js",
    "test:mcp-sse": "node tests/mcp/test-sse.js",
    "test:mcp-stdio": "node tests/mcp/test-stdio.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "typescript",
    "template",
    "ai",
    "prompts",
    "tools",
    "resources"
  ],
  "author": {
    "name": "{{author.name}}",
    "email": "{{author.email}}"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.1",
    "fa-mcp-sdk": "^0.4.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://{{git-base-url}}/{{project.name}}.git"
  }
}
